# --- Dökümanlarım - Production example (DO NOT COMMIT REAL SECRETS) ---

NODE_ENV=production
PORT=3333

# Your public URL
BASE_URL=https://dokumanlarim.com

# If behind Cloudflare/Render proxy
TRUST_PROXY=1
FORCE_HTTPS=1
COOKIE_SECURE=1

# Required: use key rotation format
# Generate with: npm run gen:secrets
SESSION_SECRETS=CHANGE_ME_KEY1,CHANGE_ME_KEY2

# Optional but recommended
CAPTCHA_SIGNING_SECRET=CHANGE_ME_RANDOM
SUPPORT_EMAIL=ceylanatay@dokumanlarim.com

# Turnstile (optional but recommended in public launch)
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# Security alert webhook (Slack/Teams/Discord webhook URL)
# SECURITY_ALERT_WEBHOOK_URL=

# SMTP (for invite/reminder emails)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="Dökümanlarım <noreply@dokumanlarim.com>"

# Storage
# STORAGE_PROVIDER=local
# For local, make sure you have persistent disk in prod.
