# ===== Server =====
PORT=3000
NODE_ENV=development

# Production için en az 24+ karakter rastgele bir değer gir.
SESSION_SECRET=change-me-please-very-long-random-string

# Boş ise uygulama host/protocol'ü request'ten türetir.
# Prod'da mutlaka HTTPS domain ver: https://app.senindomain.com
BASE_URL=

# Reverse proxy arkasında isen (Nginx/Caddy/Cloudflare)
TRUST_PROXY=0
FORCE_HTTPS=0
COOKIE_SECURE=0


# ===== Branding / Support =====
APP_NAME=Dökümanlarım
SUPPORT_EMAIL=ceylanatay@dokumanlarim.com


# ===== Upload limits =====
FILE_MAX_MB=15


# ===== Email (SMTP) =====
# Email doğrulama + şifre sıfırlama için SMTP şart.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Dökümanlarım <noreply@example.com>"


# ===== Auth / Security =====
# 1 yaparsan doğrulanmamış kullanıcılar /app alanına giremez.
EMAIL_VERIFICATION_REQUIRED=0

# Global per-IP request limit (10 min window)
GLOBAL_RATE_LIMIT_MAX=2000

# Account lockout on repeated wrong password
LOGIN_LOCK_MAX_FAILS=10
LOGIN_LOCK_MINUTES=30

# Content Security Policy (CSP)
CSP_ENABLED=1
CSP_REPORT_ONLY=0

# Password hashing cost
BCRYPT_ROUNDS=12

# Signup CAPTCHA (Cloudflare Turnstile)
# https://developers.cloudflare.com/turnstile/
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# ===== Billing (iyzico) =====
BILLING_ENABLED=0
BILLING_PROVIDER=iyzico

# Sandbox: https://sandbox-api.iyzipay.com
# Live:    https://api.iyzipay.com
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=

# Pricing plan reference codes (iyzico panelinden)
IYZICO_PLAN_STARTER_REF=
IYZICO_PLAN_TEAM_REF=
IYZICO_PLAN_PRO_REF=

# Optional: allow manual plan change with this secret (prod'da kapat)
BILLING_ADMIN_SECRET=


# ===== Outgoing Webhooks =====
OUTGOING_WEBHOOK_SECRET=

# (Opsiyonel) Tenant bağımsız güvenlik alarmları (Slack/Teams/webhook)
SECURITY_ALERT_WEBHOOK_URL=


# ===== Reminders / Cleanup =====
# Default reminder days for new companies (comma separated): e.g. 3,1
REMINDER_DEFAULT_DAYS=3,1

# Cron for reminder job (every hour by default, minute 7)
REMINDER_CRON=7 * * * *

# Cleanup archived requests older than retentionDays
CLEANUP_ENABLED=1
CLEANUP_CRON=15 3 * * *


# ===== Storage (optional) =====
# local or s3 (S3 compatible: AWS S3 / Cloudflare R2 / MinIO)
STORAGE_PROVIDER=local

# --- S3/R2 settings (only if STORAGE_PROVIDER=s3) ---
# For AWS: leave endpoint empty. For R2: https://<accountid>.r2.cloudflarestorage.com
S3_ENDPOINT=
# AWS region (e.g. eu-central-1). For R2 use: auto
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# For MinIO/R2 sometimes you need path-style URLs
S3_FORCE_PATH_STYLE=0
