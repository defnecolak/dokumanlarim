<div class="grid two" style="margin-top:20px;">
  <div class="card">
    <h2>Yeni şifre belirle</h2>
    <div class="p">Yeni şifreni gir ve kaydet.</div>
    <form method="post" action="/reset-password" style="margin-top:10px;">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="token" value="<%= token %>">
      <label>Yeni şifre</label>
      <input name="password" type="password" required minlength="8" />
      <label>Yeni şifre (tekrar)</label>
      <input name="password2" type="password" required minlength="8" />
      <div class="small">En az 8 karakter.</div>
      <div class="hr"></div>
      <button class="btn primary" type="submit">Şifreyi güncelle</button>
      <a class="btn" href="/login">Girişe dön</a>
    </form>
  </div>

  <div class="card">
    <h2>Güvenlik</h2>
    <div class="p">
      Bu link belirli bir süre geçerlidir. Süre dolduysa yeni bir sıfırlama talebi oluştur.
    </div>
  </div>
</div>
