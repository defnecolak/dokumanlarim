<div class="card" style="margin-top:20px;max-width:700px;">
  <h2>Davet kabul et</h2>
  <div class="p">
    Şirket: <b><%= tenant.name %></b><br/>
    E-posta: <b><%= invite.email %></b><br/>
    Rol: <span class="kbd"><%= invite.role %></span>
  </div>

  <form method="post" action="/invite/<%= invite.token %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="row">
      <div>
        <label>Ad</label>
        <input name="firstName" required>
      </div>
      <div>
        <label>Soyad</label>
        <input name="lastName" required>
      </div>
    </div>

    <label>Şifre</label>
    <input name="password" type="password" minlength="8" required>

    <label>Şifre (tekrar)</label>
    <input name="password2" type="password" minlength="8" required>

    <button class="btn primary" type="submit" style="margin-top:12px;">Hesabı oluştur</button>
  </form>

  <div class="small" style="margin-top:12px;">Bu link tek kullanımlıktır. Süresi dolduysa yeniden davet isteyin.</div>
</div>
