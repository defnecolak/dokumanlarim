<div style="margin-top:20px;">
  <h2 style="margin-bottom:16px;">Kontrol Paneli</h2>

  <!-- Metrik Kartları -->
  <div class="dash-grid">
    <div class="card" style="text-align:center;">
      <div class="small muted" style="text-transform:uppercase;letter-spacing:0.5px;">Toplam Talep</div>
      <div style="font-size:2em;font-weight:700;color:#1e40af;margin:6px 0;"><%= stats.totalRequests %></div>
      <div class="small muted">Tüm zamanlar</div>
    </div>
    <div class="card" style="text-align:center;">
      <div class="small muted" style="text-transform:uppercase;letter-spacing:0.5px;">Aktif Talep</div>
      <div style="font-size:2em;font-weight:700;color:#7c3aed;margin:6px 0;"><%= stats.activeRequests %></div>
      <div class="small muted">İşlemde</div>
    </div>
    <div class="card" style="text-align:center;">
      <div class="small muted" style="text-transform:uppercase;letter-spacing:0.5px;">Bekleyen Belge</div>
      <div style="font-size:2em;font-weight:700;color:#b45309;margin:6px 0;"><%= stats.pendingDocs %></div>
      <div class="small muted">Gönderim bekliyor</div>
    </div>
    <div class="card" style="text-align:center;">
      <div class="small muted" style="text-transform:uppercase;letter-spacing:0.5px;">Tamamlanma</div>
      <div style="font-size:2em;font-weight:700;color:#15803d;margin:6px 0;"><%= stats.completionRate %>%</div>
      <div class="small muted">Zorunlu belgeler</div>
    </div>
  </div>

  <!-- İki Sütun: Süresi Dolanlar + Son Aktiviteler -->
  <div class="grid two" style="margin-top:18px;">
    <div class="card">
      <h2>Yaklaşan Son Kullanma</h2>
      <% if (expiringDocs && expiringDocs.length > 0) { %>
        <div class="table-responsive">
          <table class="table">
            <thead>
              <tr><th>Tedarikçi</th><th>Belge</th><th>Tarih</th><th>Kalan</th></tr>
            </thead>
            <tbody>
              <% expiringDocs.forEach(d => { %>
                <tr>
                  <td class="small"><%= d.vendorName %></td>
                  <td class="small"><b><%= d.docLabel %></b></td>
                  <td class="small"><%= d.expiryDate %></td>
                  <td>
                    <span class="pill <%= d.daysLeft < 7 ? 'err' : d.daysLeft < 30 ? 'warn' : 'ok' %>">
                      <%= d.daysLeft %> gün
                    </span>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="p muted" style="text-align:center;padding:20px 0;">Yaklaşan son tarih yok.</div>
      <% } %>
    </div>

    <div class="card">
      <h2>Son Aktiviteler</h2>
      <% if (recentActivity && recentActivity.length > 0) { %>
        <div style="max-height:400px;overflow-y:auto;">
          <% recentActivity.forEach((a, i) => { %>
            <div style="padding:8px 0;<%= i < recentActivity.length - 1 ? 'border-bottom:1px solid rgba(0,0,0,0.06);' : '' %>">
              <div style="display:flex;justify-content:space-between;align-items:baseline;gap:8px;flex-wrap:wrap;">
                <div>
                  <b class="small"><%= a.actor %></b>
                  <span class="badge" style="font-size:0.7em;margin-left:4px;"><%= a.action %></span>
                </div>
                <span class="small muted"><%= (a.at||'').slice(0,16).replace('T',' ') %></span>
              </div>
              <% if (a.detailText) { %><div class="small muted" style="margin-top:2px;"><%= a.detailText %></div><% } %>
              <% if (a.requestId) { %><a href="/app/requests/<%= encodeURIComponent(a.requestId) %>" class="small" style="font-size:0.75em;">Talebi aç →</a><% } %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="p muted" style="text-align:center;padding:20px 0;">Henüz aktivite yok.</div>
      <% } %>
    </div>
  </div>

  <!-- Alt Özet Satırı -->
  <div class="dash-grid" style="margin-top:18px;">
    <div class="card" style="text-align:center;">
      <div class="small muted">Toplam Tedarikçi</div>
      <div style="font-size:1.6em;font-weight:700;color:#0f172a;margin:4px 0;"><%= stats.totalVendors %></div>
    </div>
    <div class="card" style="text-align:center;">
      <div class="small muted">Ort. Tamamlama Süresi</div>
      <div style="font-size:1.6em;font-weight:700;color:#0f172a;margin:4px 0;"><%= stats.avgCompletionDays %></div>
      <div class="small muted">gün</div>
    </div>
    <div class="card" style="text-align:center;">
      <div class="small muted">Yakında Sona Erecek</div>
      <div style="font-size:1.6em;font-weight:700;color:<%= expiringDocs.length > 0 ? '#b91c1c' : '#15803d' %>;margin:4px 0;"><%= expiringDocs.length %></div>
      <div class="small muted"><%= expiringDocs.length > 0 ? 'belge' : 'Hepsi temiz' %></div>
    </div>
  </div>
</div>
